// ============================================================
// MOODBOARD — Schéma Prisma
// PostgreSQL via Neon (serverless)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// UTILISATEUR (multi-profils)
// ============================================================
model User {
  id            String     @id @default(cuid())
  email         String     @unique
  passwordHash  String
  name          String?
  // ADMIN = propriétaire de l'instance : crée/supprime les profils, règle les quotas.
  // USER = profil standard, ne voit que ses propres données.
  role          UserRole   @default(USER)
  // Quota de stockage R2 alloué à ce profil (octets). La somme des quotas de tous
  // les profils est plafonnée à QUOTA.MAX_STORAGE_BYTES (garde-fou à l'attribution,
  // voir lib/storage/quota.ts). BigInt car un quota > ~2,1 Go dépasse Int32.
  storageQuotaBytes BigInt @default(1073741824) // 1 Gio par défaut
  // Avatar : storageKey R2 (même bucket que les images) — null = pas de photo
  image         String?
  // Poids de l'avatar sur R2 — inclus dans getStorageQuota()
  imageSize     Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  apiTokens        ApiToken[]
  inspirations     Inspiration[]
  collections      Collection[]
  moodboards       Moodboard[]
  moodboardFolders MoodboardFolder[]
  visits           Visit[]
  tags             Tag[]

  @@map("users")
}

enum UserRole {
  ADMIN
  USER
}

model ApiToken {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String    @unique
  name        String    @default("Extension Chrome")
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?

  @@map("api_tokens")
}

// ============================================================
// CATÉGORIE
// ============================================================
model Category {
  id            String        @id @default(cuid())
  name          String        @unique
  slug          String        @unique
  icon          String?
  description   String?
  order         Int           @default(0)
  createdAt     DateTime      @default(now())

  subcategories          Subcategory[]
  inspirationCategories  InspirationCategory[]

  @@map("categories")
}

model Subcategory {
  id          String        @id @default(cuid())
  name        String
  slug        String
  categoryId  String
  order       Int           @default(0)

  category              Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  inspirationCategories InspirationCategory[]

  @@unique([categoryId, slug])
  @@map("subcategories")
}

// Many-to-many: une inspiration peut appartenir à plusieurs catégories
model InspirationCategory {
  inspirationId  String
  categoryId     String
  subcategoryId  String?

  inspiration    Inspiration  @relation(fields: [inspirationId], references: [id], onDelete: Cascade)
  category       Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subcategory    Subcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)

  @@id([inspirationId, categoryId])
  @@map("inspiration_categories")
}

// ============================================================
// TAG
// ============================================================
model Tag {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  slug         String
  source       TagSource    @default(MANUAL)
  createdAt    DateTime     @default(now())

  inspirations InspirationTag[]

  // Unicité par profil : chaque utilisateur a son propre espace de tags
  @@unique([userId, name])
  @@unique([userId, slug])
  @@index([userId])
  @@map("tags")
}

enum TagSource {
  MANUAL
  AI
}

// ============================================================
// INSPIRATION — Entité principale
// ============================================================
model Inspiration {
  id             String         @id @default(cuid())
  // Propriétaire du profil
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String
  description    String?

  // Crédits
  author         String?
  year           Int?
  country        String?

  // Contexte
  exposition     String?
  location       String?
  source         String?
  sourceUrl      String?

  // Visite (musée / exposition) — contexte de collecte
  visitId        String?
  visit          Visit?         @relation(fields: [visitId], references: [id], onDelete: SetNull)
  // Position dans le carnet de la visite (même espace de tri que VisitNote.order)
  visitOrder     Int            @default(0)

  // Classification
  mediaType      MediaType      @default(IMAGE)

  // Triage — archivé (masqué de la bibliothèque, conservé en DB)
  isArchived     Boolean        @default(false)
  // Triage — accepté explicitement par l'utilisateur (visible dans la bibliothèque)
  isAccepted     Boolean        @default(false)

  // Statut traitement
  status         InspirationStatus @default(PROCESSING)

  // Timestamps
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relations
  categories     InspirationCategory[]
  images         Image[]
  tags           InspirationTag[]
  collections    CollectionItem[]
  colorPalette   InspirationColor[]
  videoImport    VideoImport?

  @@index([year])
  @@index([status])
  @@index([createdAt])
  @@index([visitId])
  @@index([userId])
  @@map("inspirations")
}

// ============================================================
// VISIT — Carnet de visite (musée / exposition)
// ============================================================
model Visit {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  place        String        // Lieu : musée, galerie, ville…
  exhibition   String?       // Nom de l'exposition (optionnel)
  visitDate    DateTime      // Date de la visite
  notes        String?
  // Géolocalisation (OpenStreetMap / Photon) — pour la mini-carte
  latitude     Float?
  longitude    Float?
  address      String?       // Adresse d'affichage retournée par le géocodeur
  // Partage public (Phase 5) — même pattern que Moodboard. Token nul = privé
  // (non partagé) ; posé/révoqué via /api/visits/[id]/share.
  shareToken   String?       @unique
  shareExpiry  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  inspirations Inspiration[]
  noteBlocks   VisitNote[]
  audioClips   VisitAudio[]
  quoteBlocks  VisitQuote[]
  titleBlocks  VisitTitle[]
  columnBlocks VisitColumns[]
  embeds       VisitEmbed[]

  @@index([visitDate])
  @@index([userId])
  @@map("visits")
}

// ── Carnet façon Notion (2026-07-13) ────────────────────────────────────────
// Chaque type de bloc reste dans sa propre table (image = Inspiration, texte
// = VisitNote, citation = VisitQuote, audio = VisitAudio) — PAS de table
// polymorphique unique. `order` partage le même espace de tri sur les 5
// tables au sein d'une visite (place dans la séquence du carnet).
// Chaque bloc est PUR : un bloc texte ne contient plus d'image/audio/citation
// intégrés (contrainte produit explicite — "on prend le parti pris de
// Notion"). `VisitColumns` compose DES LISTES de blocs existants côte à
// côte (une pile par côté, pas juste un bloc — "titre puis texte puis
// audio" dans une même colonne) en référençant leur (type, id) dans un
// tableau JSON `[{type,id}, ...]` : pas de FK typée possible sur un id
// polymorphique en Prisma, et un tableau de paires typées n'a pas
// d'équivalent relationnel simple sans table de jonction dédiée — un champ
// Json reste le plus direct, résolu et validé au niveau applicatif. Un bloc
// "réclamé" par une colonne (son id apparaît dans un des deux tableaux) est
// exclu de la séquence plate au niveau applicatif, pas contraint en base.

// Enregistrement audio — bloc autonome du carnet (waveform + lecture ±15s +
// transcription). Modèle dédié (plutôt qu'une clé R2 brute) pour compter
// l'audio dans le quota de stockage par profil et nettoyer R2 proprement.
model VisitAudio {
  id          String   @id @default(cuid())
  visitId     String
  visit       Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
  storageKey  String
  size        Int
  durationSec Int?
  // Transcription (live Web Speech ou Whisper local à la demande) — éditable,
  // vide si non transcrit. Bloc autonome depuis le 2026-07-13 (avant : notes
  // avec bloc audio + paragraphe transcript intégrés).
  transcript  String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([visitId])
  @@map("visit_audio")
}

// Bloc de texte pur du carnet (sous-titre H3, gras/italique, listes — le
// Titre H2 est un bloc à part, VisitTitle ci-dessous ; plus de
// citation/image/audio intégrés, voir note ci-dessus).
model VisitNote {
  id        String   @id @default(cuid())
  visitId   String
  visit     Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
  content   String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([visitId])
  @@map("visit_notes")
}

// Bloc citation — mise en avant typographique, séparé du texte courant.
model VisitQuote {
  id        String   @id @default(cuid())
  visitId   String
  visit     Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
  content   String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([visitId])
  @@map("visit_quotes")
}

// Bloc titre — grand intitulé de section (texte brut, pas de rich text),
// promu bloc autonome le 2026-07-13 (avant : formatage H2 à l'intérieur d'un
// bloc texte). Même forme que VisitQuote.
model VisitTitle {
  id        String   @id @default(cuid())
  visitId   String
  visit     Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
  content   String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([visitId])
  @@map("visit_titles")
}

// Bloc "2 colonnes" — compose deux PILES de blocs existants côte à côte
// (texte/titre/citation/image/audio, pas de colonnes imbriquées). Chaque
// pile est un tableau JSON ordonné `[{type: "IMAGE"|"TEXT"|"TITLE"|"QUOTE"|
// "AUDIO", id: string}, ...]` — pile vide = "[]".
model VisitColumns {
  id        String   @id @default(cuid())
  visitId   String
  visit     Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
  left      Json     @default("[]")
  right     Json     @default("[]")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([visitId])
  @@map("visit_columns")
}

// Bloc "lien externe" et "embed YouTube" du carnet (2026-07-14) — même table,
// discriminée par `kind`. LINK : carte d'aperçu (métadonnées Open Graph
// récupérées côté serveur à la création — title/description/image/siteName,
// URLs externes, pas de R2). YOUTUBE : l'URL est transformée en iframe au
// rendu (title/miniature via oEmbed). Bloc TOP-LEVEL uniquement : pas
// réclamable dans une colonne (contrairement aux blocs purs), donc absent
// des refs VisitColumns.
model VisitEmbed {
  id          String         @id @default(cuid())
  visitId     String
  visit       Visit          @relation(fields: [visitId], references: [id], onDelete: Cascade)
  kind        VisitEmbedKind @default(LINK)
  url         String
  title       String?
  description String?
  image       String?
  siteName    String?
  order       Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([visitId])
  @@map("visit_embeds")
}

enum VisitEmbedKind {
  LINK
  YOUTUBE
}

enum MediaType {
  IMAGE
  VIDEO
  MIXED
}

enum InspirationStatus {
  PROCESSING
  READY
  ERROR
}

// ============================================================
// IMAGE
// ============================================================
model Image {
  id             String      @id @default(cuid())
  inspirationId  String
  filename       String
  originalName   String
  mimeType       String
  size           Int
  // Poids de la vignette R2 — 2e objet stocké par image, absent des totaux
  // de quota avant ce champ (voir getStorageQuota)
  thumbnailSize  Int         @default(0)
  width          Int?
  height         Int?
  storageKey     String
  thumbnailKey   String?
  blurHash       String?
  isMain         Boolean     @default(false)
  isAnimated     Boolean     @default(false)
  order          Int         @default(0)
  exifData       Json?
  createdAt      DateTime    @default(now())

  inspiration    Inspiration @relation(fields: [inspirationId], references: [id], onDelete: Cascade)

  @@index([inspirationId])
  @@map("images")
}

// ============================================================
// TAGS (liaison M:M)
// ============================================================
model InspirationTag {
  inspirationId  String
  tagId          String
  assignedAt     DateTime    @default(now())

  inspiration    Inspiration @relation(fields: [inspirationId], references: [id], onDelete: Cascade)
  tag            Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([inspirationId, tagId])
  @@map("inspiration_tags")
}

// ============================================================
// COLLECTION
// ============================================================
model Collection {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  coverImageKey  String?
  isPublic       Boolean         @default(false)
  order          Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  items          CollectionItem[]

  @@index([userId])
  @@map("collections")
}

model CollectionItem {
  collectionId   String
  inspirationId  String
  order          Int             @default(0)
  addedAt        DateTime        @default(now())

  collection     Collection      @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  inspiration    Inspiration     @relation(fields: [inspirationId], references: [id], onDelete: Cascade)

  @@id([collectionId, inspirationId])
  @@map("collection_items")
}

// ============================================================
// COULEURS DOMINANTES
// ============================================================
model InspirationColor {
  id              String      @id @default(cuid())
  inspirationId   String
  hex             String
  r               Int
  g               Int
  b               Int
  percentage      Float
  order           Int         @default(0)

  inspiration     Inspiration @relation(fields: [inspirationId], references: [id], onDelete: Cascade)

  @@index([inspirationId])
  @@index([hex])
  @@map("inspiration_colors")
}

// ============================================================
// IMPORT VIDÉO
// ============================================================
model VideoImport {
  id              String            @id @default(cuid())
  inspirationId   String?           @unique
  sourceUrl       String
  platform        VideoPlatform
  title           String?
  duration        Int?
  status          VideoImportStatus @default(PENDING)
  extractedStills Json?
  selectedStills  String[]
  errorMessage    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  inspiration     Inspiration?      @relation(fields: [inspirationId], references: [id])

  @@map("video_imports")
}

enum VideoPlatform {
  YOUTUBE
  VIMEO
  OTHER
}

enum VideoImportStatus {
  PENDING
  PROCESSING
  SELECTING
  DONE
  ERROR
}

// ============================================================
// MOODBOARD — Planche d'ambiance
// ============================================================
model Moodboard {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String    @default("Sans titre")
  canvasData     Json      @default("[]")
  pencilStrokes  Json      @default("[]")
  background     String    @default("#0a0a0a")
  shareToken     String?   @unique @default(uuid())
  shareExpiry    DateTime?
  order          Int       @default(0)
  folderId       String?
  folder         MoodboardFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId])
  @@map("moodboards")
}

model MoodboardFolder {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  order      Int         @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  moodboards Moodboard[]

  @@index([userId])
  @@map("moodboard_folders")
}
