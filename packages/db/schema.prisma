// ============================================================
// MOODBOARD — Schéma Prisma
// PostgreSQL via Neon (serverless)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// UTILISATEUR (un seul pour le MVP)
// ============================================================
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

// ============================================================
// CATÉGORIE
// ============================================================
model Category {
  id            String        @id @default(cuid())
  name          String        @unique
  slug          String        @unique
  icon          String?
  description   String?
  order         Int           @default(0)
  createdAt     DateTime      @default(now())

  subcategories Subcategory[]
  inspirations  Inspiration[]

  @@map("categories")
}

model Subcategory {
  id          String        @id @default(cuid())
  name        String
  slug        String
  categoryId  String
  order       Int           @default(0)

  category     Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  inspirations Inspiration[]

  @@unique([categoryId, slug])
  @@map("subcategories")
}

// ============================================================
// TAG
// ============================================================
model Tag {
  id           String       @id @default(cuid())
  name         String       @unique
  slug         String       @unique
  source       TagSource    @default(MANUAL)
  createdAt    DateTime     @default(now())

  inspirations InspirationTag[]

  @@map("tags")
}

enum TagSource {
  MANUAL
  AI
}

// ============================================================
// INSPIRATION — Entité principale
// ============================================================
model Inspiration {
  id             String         @id @default(cuid())
  title          String
  description    String?

  // Crédits
  author         String?
  studio         String?
  year           Int?
  country        String?

  // Contexte
  exposition     String?
  location       String?
  source         String?
  sourceUrl      String?

  // Classification
  mediaType      MediaType      @default(IMAGE)
  categoryId     String?
  subcategoryId  String?

  // Notes personnelles
  notes          String?

  // Statut traitement
  status         InspirationStatus @default(PROCESSING)

  // Timestamps
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relations
  category       Category?      @relation(fields: [categoryId], references: [id])
  subcategory    Subcategory?   @relation(fields: [subcategoryId], references: [id])
  images         Image[]
  tags           InspirationTag[]
  collections    CollectionItem[]
  aiAnalysis     AIAnalysis?
  colorPalette   InspirationColor[]
  videoImport    VideoImport?

  @@index([categoryId])
  @@index([year])
  @@index([status])
  @@index([createdAt])
  @@map("inspirations")
}

enum MediaType {
  IMAGE
  VIDEO
  MIXED
}

enum InspirationStatus {
  PROCESSING
  READY
  ERROR
}

// ============================================================
// IMAGE
// ============================================================
model Image {
  id             String      @id @default(cuid())
  inspirationId  String
  filename       String
  originalName   String
  mimeType       String
  size           Int
  width          Int?
  height         Int?
  storageKey     String
  thumbnailKey   String?
  blurHash       String?
  isMain         Boolean     @default(false)
  order          Int         @default(0)
  exifData       Json?
  createdAt      DateTime    @default(now())

  inspiration    Inspiration @relation(fields: [inspirationId], references: [id], onDelete: Cascade)

  @@index([inspirationId])
  @@map("images")
}

// ============================================================
// TAGS (liaison M:M)
// ============================================================
model InspirationTag {
  inspirationId  String
  tagId          String
  assignedAt     DateTime    @default(now())

  inspiration    Inspiration @relation(fields: [inspirationId], references: [id], onDelete: Cascade)
  tag            Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([inspirationId, tagId])
  @@map("inspiration_tags")
}

// ============================================================
// COLLECTION
// ============================================================
model Collection {
  id             String          @id @default(cuid())
  name           String
  description    String?
  coverImageKey  String?
  isPublic       Boolean         @default(false)
  order          Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  items          CollectionItem[]

  @@map("collections")
}

model CollectionItem {
  collectionId   String
  inspirationId  String
  order          Int             @default(0)
  addedAt        DateTime        @default(now())

  collection     Collection      @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  inspiration    Inspiration     @relation(fields: [inspirationId], references: [id], onDelete: Cascade)

  @@id([collectionId, inspirationId])
  @@map("collection_items")
}

// ============================================================
// ANALYSE IA
// ============================================================
model AIAnalysis {
  id              String      @id @default(cuid())
  inspirationId   String      @unique
  rawResponse     Json
  styleKeywords   String[]
  moodDescriptor  String?
  technicalNotes  String?
  processedAt     DateTime    @default(now())

  inspiration     Inspiration @relation(fields: [inspirationId], references: [id], onDelete: Cascade)

  @@map("ai_analyses")
}

// ============================================================
// COULEURS DOMINANTES
// ============================================================
model InspirationColor {
  id              String      @id @default(cuid())
  inspirationId   String
  hex             String
  r               Int
  g               Int
  b               Int
  percentage      Float
  order           Int         @default(0)

  inspiration     Inspiration @relation(fields: [inspirationId], references: [id], onDelete: Cascade)

  @@index([inspirationId])
  @@index([hex])
  @@map("inspiration_colors")
}

// ============================================================
// IMPORT VIDÉO
// ============================================================
model VideoImport {
  id              String            @id @default(cuid())
  inspirationId   String?           @unique
  sourceUrl       String
  platform        VideoPlatform
  title           String?
  duration        Int?
  status          VideoImportStatus @default(PENDING)
  extractedStills Json?
  selectedStills  String[]
  errorMessage    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  inspiration     Inspiration?      @relation(fields: [inspirationId], references: [id])

  @@map("video_imports")
}

enum VideoPlatform {
  YOUTUBE
  VIMEO
  OTHER
}

enum VideoImportStatus {
  PENDING
  PROCESSING
  SELECTING
  DONE
  ERROR
}
